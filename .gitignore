# ── Dependencies ────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ────────────────────────────────────────
/.next/
/out/
/build

# ── Environment variables (NEVER commit secrets) ────────────────
.env
.env.*
!.env.example

# ── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing & coverage ──────────────────────────────────────────
/coverage
/.nyc_output

# ── Package manager debug logs ──────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ── Vercel ──────────────────────────────────────────────────────
.vercel

# ── OS files ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TLS / certificates ──────────────────────────────────────────
*.pem

# ── Compiled scripts ────────────────────────────────────────────
/scripts/*.js
/scripts/*.mjs

# ── Misc ────────────────────────────────────────────────────────
*.log
/tmp
/temp
